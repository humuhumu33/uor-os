{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "UOR-OS",
  "version": "2.0.0",
  "identifier": "foundation.uor.os",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "UOR OS",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://*.supabase.co https://*.supabase.in wss://*.supabase.co https://api.lovable.dev https://*.lovable.app https://github.com https://api.github.com https://objects.githubusercontent.com; img-src 'self' data: blob: https:; font-src 'self' data:; media-src 'self' blob:; worker-src 'self' blob:; frame-src 'self' https:"
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "UOR OS"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/humuhumu33/uor-os/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_YOUR_UPDATER_PUBKEY"
    },
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$HOME/.uor/**"],
        "deny": []
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": ["uor"]
      }
    }
  }
}
