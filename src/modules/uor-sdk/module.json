{
  "@context": "https://uor.foundation/contexts/uor-v1.jsonld",
  "@type": "uor:Module",
  "name": "uor-sdk",
  "version": "1.0.0",
  "description": "Typed TypeScript bridge to the live UOR REST API. Trust anchor for all app-platform modules.",
  "uor:specification": "1.0.0",
  "uor:namespaces": [
    "u:", "schema:", "op:", "kernel:",
    "partition:", "trace:", "observable:",
    "derivation:", "cert:", "morphism:",
    "store:", "proof:", "state:", "tsp:", "fpp:", "trqp:", "polytree:"
  ],
  "exports": [
    "createUorClient",
    "UorApiError",
    "neg", "bnot", "succ",
    "verifyCriticalIdentity",
    "singleProofHash",
    "computeModuleIdentity",
    "resolveVid",
    "sealEnvelope",
    "createRfi",
    "acceptRfi",
    "verifyEnvelope",
    "verifyRelationship",
    "issuePhc",
    "issueVrc",
    "issueVec",
    "createPersona",
    "createRcard",
    "createTrustGraphNode",
    "exchangeVrcs",
    "verifyPhc",
    "verifyVrc",
    "verifyTrustTriangle",
    "constantTree",
    "evolvingTree",
    "tensorProduct",
    "coproduct",
    "internalHom",
    "identityMorphism",
    "composeMorphisms",
    "executeInteraction",
    "truncate",
    "fppTrustEvolutionTree",
    "tspChannelEvolutionTree",
    "agentCapabilityEvolutionTree"
  ],
  "dependencies": {
    "core": "^1.0.0"
  },
  "routes": [],
  "api_endpoints": [
    "/kernel/op/verify",
    "/kernel/op/compute",
    "/kernel/address/encode",
    "/bridge/partition",
    "/bridge/trace",
    "/store/write",
    "/store/read/:cid",
    "/store/verify/:cid"
  ],
  "assets": []
}
